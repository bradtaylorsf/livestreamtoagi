# LLM Routing
# LLM_PROVIDER selects which LLM backend to use. Leave blank to default to
# 'openrouter'. For LM Studio set LLM_PROVIDER=lmstudio.
LLM_PROVIDER=
OPENROUTER_API_KEY=
# LM Studio / OpenAI-compatible local server. Defaults shown in comments below;
# leave blank to use the in-code default.
#   LOCAL_LLM_BASE_URL default: http://localhost:1234/v1
#   LOCAL_LLM_API_KEY  default: lm-studio
LOCAL_LLM_BASE_URL=
LOCAL_LLM_API_KEY=
LOCAL_LLM_MODEL=
# Optional: heavier local model used for building-tier calls (reflection, dreams,
# anything mapped to claude-sonnet/gemini-pro/gpt-5.2/grok-3). Falls back to
# LOCAL_LLM_MODEL when unset.
LOCAL_LLM_MODEL_BUILDING=
LOCAL_LLM_PASSTHROUGH_MODEL=

# Embeddings
# Default follows LLM_PROVIDER. Local LLM runs use deterministic embeddings
# unless EMBEDDING_PROVIDER is set to lmstudio/openai-compatible.
#   EMBEDDING_BASE_URL    default: http://localhost:1234/v1
#   EMBEDDING_API_KEY     default: lm-studio
#   LOCAL_EMBEDDING_MODEL default: text-embedding-nomic-embed-text-v1.5
EMBEDDING_PROVIDER=
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
LOCAL_EMBEDDING_MODEL=

# Twitch
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_BOT_TOKEN=

# YouTube
YOUTUBE_API_KEY=
# YouTube auto-publish (opt-in per-simulation; off by default).
# Generate the refresh token by running an OAuth flow with the
# `https://www.googleapis.com/auth/youtube.upload` scope and storing the
# resulting refresh_token here.
#   YOUTUBE_DEFAULT_PRIVACY default: unlisted
#   YOUTUBE_MAX_RETRIES    default: 3
YOUTUBE_PUBLISH_ENABLED=
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_DEFAULT_PRIVACY=
YOUTUBE_MAX_RETRIES=

# Asset Generation
PIXELLAB_API_KEY=

# Langfuse (Observability) — get these from http://localhost:3100 after first login
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=

# Database (port must match POSTGRES_PORT in docker-compose, default 5434)
DATABASE_URL=postgresql://agi:devpassword@localhost:5434/livestream_agi
TEST_DATABASE_URL=postgresql://agi:devpassword@localhost:5434/livestream_agi_test
POSTGRES_PASSWORD=devpassword

# Redis (port must match REDIS_PORT in docker-compose, default 6381)
REDIS_URL=redis://:devpassword@localhost:6381
REDIS_PASSWORD=devpassword

# Security
KILL_SWITCH_API_KEY=
ADMIN_PASSWORD=
# ADMIN_PASSWORD_HASH= # bcrypt hash of admin password (preferred over plaintext)
# ADMIN_JWT_SECRET= # secret for signing admin session cookies

# Public user auth (magic-link email flow — see /api/auth/*)
# EMAIL_PROVIDER selects the transactional email backend.
#   resend  — POST to api.resend.com (requires EMAIL_API_KEY)
#   ses     — placeholder; not yet implemented
#   console — log to stdout + jsonl file (default; useful for dev/tests)
EMAIL_PROVIDER=
EMAIL_API_KEY=
EMAIL_FROM=
# Console-provider QA capture: each "sent" email is appended as JSON to this
# file so you can `tail -f` to grab the magic-link URL during dev.
EMAIL_CONSOLE_LOG=/tmp/livestream-agi-emails.jsonl
# Optional: also XADD each console email to this Redis stream (uses REDIS_URL).
# Leave blank to skip — set e.g. `stream:email:console` to enable.
EMAIL_CONSOLE_REDIS_STREAM=
# Secret for signing user session JWTs. Generate with: openssl rand -hex 32
AUTH_JWT_SECRET=
# Base URL of the public-facing website (Next.js). Used for magic-link verify
# URLs, simulation-complete emails, and the video renderer's replay page —
# the headless Chromium points at `${PUBLIC_BASE_URL}/simulations/{id}/replay`.
PUBLIC_BASE_URL=http://localhost:3000

# Public simulation submission caps (see /api/simulations/submit)
PUBLIC_SIM_MAX_COST_USD=
PUBLIC_USER_LIFETIME_CAP_USD=

# Langfuse Auth (used by docker-compose for Langfuse container)
LANGFUSE_NEXTAUTH_SECRET=dev-secret-change-me
LANGFUSE_SALT=dev-salt-change-me

# Environment (set to "production" to disable /api/dev/* endpoints)
ENV=development

# CORS (comma-separated extra origins, e.g. https://admin.example.com)
CORS_ORIGINS=

# Website (used by Next.js rewrite proxy — server-side only)
BACKEND_URL=http://localhost:8010
NEXT_PUBLIC_WS_URL=ws://localhost:8010/ws
