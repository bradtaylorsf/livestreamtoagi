# LLM Routing
# LLM_PROVIDER selects which LLM backend to use. Leave blank to default to
# 'openrouter'. For LM Studio set LLM_PROVIDER=lmstudio.
LLM_PROVIDER=
OPENROUTER_API_KEY=
# LM Studio / OpenAI-compatible local server. Defaults shown in comments below;
# leave blank to use the in-code default.
#   LOCAL_LLM_BASE_URL default: http://localhost:1234/v1
#   LOCAL_LLM_API_KEY  default: lm-studio
LOCAL_LLM_BASE_URL=
LOCAL_LLM_API_KEY=
LOCAL_LLM_MODEL=
# Optional: heavier local model used for building-tier calls (reflection, dreams,
# anything mapped to claude-sonnet/gemini-pro/gpt-5.2/grok-3). Falls back to
# LOCAL_LLM_MODEL when unset.
LOCAL_LLM_MODEL_BUILDING=
LOCAL_LLM_PASSTHROUGH_MODEL=

# Memory
# MEMORY_BACKEND selects the recall/archival backend. Leave blank for default.
MEMORY_BACKEND=

# Embeddings
# Default follows LLM_PROVIDER. Local LLM runs use deterministic embeddings
# unless EMBEDDING_PROVIDER is set to lmstudio/openai-compatible.
#   EMBEDDING_BASE_URL    default: http://localhost:1234/v1
#   EMBEDDING_API_KEY     default: lm-studio
#   LOCAL_EMBEDDING_MODEL default: text-embedding-nomic-embed-text-v1.5
EMBEDDING_PROVIDER=
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
LOCAL_EMBEDDING_MODEL=

# Twitch
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_BOT_TOKEN=

# YouTube
YOUTUBE_API_KEY=
# YouTube auto-publish (opt-in per-simulation; off by default).
# Generate the refresh token by running an OAuth flow with the
# `https://www.googleapis.com/auth/youtube.upload` scope and storing the
# resulting refresh_token here.
#   YOUTUBE_DEFAULT_PRIVACY default: unlisted
#   YOUTUBE_MAX_RETRIES    default: 3
YOUTUBE_PUBLISH_ENABLED=
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_DEFAULT_PRIVACY=
YOUTUBE_MAX_RETRIES=

# Livestream - RTMP push (E13-2).
# Stream keys must be supplied from a private .env or host secret store only.
# Never commit real stream keys.
#   TWITCH_RTMP_URL  default: rtmp://live.twitch.tv/app
#   YOUTUBE_RTMP_URL default: rtmp://a.rtmp.youtube.com/live2
TWITCH_STREAM_KEY=
YOUTUBE_STREAM_KEY=
TWITCH_RTMP_URL=
YOUTUBE_RTMP_URL=
# Optional local/test RTMP endpoint used by scripts/livestream/stream-push.sh --smoke.
RTMP_SMOKE_URL=

# Asset Generation
PIXELLAB_API_KEY=

# Langfuse (Observability) — get these from http://localhost:3100 after first login
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=

# Database (port must match POSTGRES_PORT in docker-compose, default 5434)
DATABASE_URL=postgresql://agi:devpassword@localhost:5434/livestream_agi
TEST_DATABASE_URL=postgresql://agi:devpassword@localhost:5434/livestream_agi_test
POSTGRES_PASSWORD=devpassword

# Redis (port must match REDIS_PORT in docker-compose, default 6381)
REDIS_URL=redis://:devpassword@localhost:6381
REDIS_PASSWORD=devpassword

# Security
KILL_SWITCH_API_KEY=
ADMIN_PASSWORD=
# ADMIN_PASSWORD_HASH= # bcrypt hash of admin password (preferred over plaintext)
# ADMIN_JWT_SECRET= # secret for signing admin session cookies; generate with: openssl rand -hex 32

# Livestream kill path (disabled by default)
LIVESTREAM_ENABLED=
LIVESTREAM_KILL_MODE=
LIVESTREAM_HOLDING_CARD=
LIVESTREAM_SAFE_TRANSITION_SECONDS=

# Public user auth (magic-link email flow — see /api/auth/*)
# EMAIL_PROVIDER selects the transactional email backend.
#   resend  — POST to api.resend.com (requires EMAIL_API_KEY)
#   ses     — placeholder; not yet implemented
#   console — log to stdout + jsonl file (default; useful for dev/tests)
EMAIL_PROVIDER=
EMAIL_API_KEY=
EMAIL_FROM=
# Console-provider QA capture: each "sent" email is appended as JSON to the
# file at EMAIL_CONSOLE_LOG so you can `tail -f` to grab the magic-link URL
# during dev. Defaults to /tmp/livestream-agi-emails.jsonl when blank.
EMAIL_CONSOLE_LOG=
# Optional: also XADD each console email to this Redis stream (uses REDIS_URL).
# Leave blank to skip — set e.g. `stream:email:console` to enable.
EMAIL_CONSOLE_REDIS_STREAM=
# Operator spend/kill alerts. ALERT_EMAIL is the human inbox for spend-cap
# approach/trip and kill-switch activation alerts. Threshold is a decimal
# fraction of the spend cap; default is 0.8 (80%).
ALERT_EMAIL=
SPEND_ALERT_THRESHOLD_PCT=
# Secret for signing user session JWTs. Generate with: openssl rand -hex 32
AUTH_JWT_SECRET=
# Public website origin used for magic links, completion emails, YouTube
# descriptions, and the default video replay capture URL. Local backend API
# runs on 8010; the website/replay app runs on 4000.
PUBLIC_BASE_URL=http://localhost:4000

# Video rendering (Playwright capture).
# Default: {PUBLIC_BASE_URL}/simulations/{sim_id}/replay?renderMode=1
# Override only when a render worker must use a different internal capture URL.
# Supported placeholders: {base_url}, {sim_id}
VIDEO_REPLAY_URL_TEMPLATE=

# Livestream TTS audio (E13-4). Backend writes decoded Edge TTS PCM to a FIFO;
# stream-push.sh reads the same FIFO when started with --with-tts.
#   TTS_STREAM_ENABLED default: 0
#   TTS_STREAM_FIFO default: /tmp/livestream_tts.fifo
#   TTS_STREAM_SAMPLE_RATE default: 44100
#   TTS_STREAM_CHANNELS default: 2
#   TTS_AUDIO_FIFO default: TTS_STREAM_FIFO or /tmp/livestream_tts.fifo
#   TTS_AUDIO_VOLUME default: 1.0
TTS_STREAM_ENABLED=
TTS_STREAM_FIFO=
TTS_STREAM_SAMPLE_RATE=
TTS_STREAM_CHANNELS=
TTS_AUDIO_FIFO=
TTS_AUDIO_VOLUME=

# Livestream health monitoring (E13-7)
# Defaults when blank:
#   STREAM_HEALTH_DOWN_THRESHOLD_SECONDS default: 30
#   STREAM_HEALTH_BLACK_SECONDS          default: 5
#   STREAM_HEALTH_SILENCE_SECONDS        default: 10
#   STREAM_HEALTH_POLL_INTERVAL          default: 15
#   STREAM_HEALTH_ALERT_COOLDOWN_SECONDS default: 300
STREAM_ALERT_EMAIL=
STREAM_SOURCE_URL=
STREAM_HEALTH_DOWN_THRESHOLD_SECONDS=
STREAM_HEALTH_BLACK_SECONDS=
STREAM_HEALTH_SILENCE_SECONDS=
STREAM_HEALTH_POLL_INTERVAL=
STREAM_HEALTH_ALERT_COOLDOWN_SECONDS=

# Public simulation submission caps (see /api/simulations/submit)
PUBLIC_SIM_MAX_COST_USD=
PUBLIC_USER_LIFETIME_CAP_USD=

# Langfuse Auth (used by docker-compose for Langfuse container)
LANGFUSE_NEXTAUTH_SECRET=dev-secret-change-me
LANGFUSE_SALT=dev-salt-change-me

# Environment (set to "production" to disable /api/dev/* endpoints)
ENV=development

# CORS (comma-separated extra origins, e.g. https://admin.example.com)
CORS_ORIGINS=

# Conversation mode.
# director = legacy Python conversation director; embodied = Mindcraft
# decentralized respond/ignore; director_v2 = embodied run with Python Director
# V2 prompt gating.
# For `pnpm mc:sim`, set this to embodied.
CONVERSATION_MODE=director

# Minecraft bridge (Node Mindcraft bots <-> Python — epic E4, decision 0010).
# Shared bearer secret the Node bridge client presents on the WebSocket
# handshake and the FastAPI bridge server checks (constant-time). The bridge has
# NO unauthenticated path: leave blank and the bot fails closed before
# connecting. Generate with: openssl rand -hex 32. Never commit the real value.
MINECRAFT_BRIDGE_TOKEN=
# Convenience defaults for `pnpm mc:sim`; override only when you want different
# first-run durations or output locations.
#   MC_SIM_SMOKE_HOURS default: 0.25
#   MC_SIM_SOAK_HOURS  default: 2
#   MC_SIM_LOG_DIR     default: logs/soak
#   MC_SIM_DISABLE_MANAGEMENT default: 1 (only for pnpm mc:sim* local sims)
#   MC_SIM_INCLUDE_BRIDGE_BOT default: 0 (BridgeBot is not a character)
#   MC_SIM_BLOCK_PRIVATE_CONVERSATIONS default: 1 (public chat/actions only)
#   MC_SIM_ALLOW_NEW_ACTION default: 0 (prefer direct movement/actions first)
#   MC_SIM_SUPPRESS_ACTION_CHAT default: 1 (hide low-level action result chatter)
#   MC_SIM_SAFE_TERRAIN_ACTIONS default: 1 (no destructive pathfinding)
#   MC_SIM_EASY_MODE default: 1 (isolated easy server + starter meadow)
#   MC_SIM_MC_PORT default: 25566 when easy mode is enabled
#   MC_SIM_MINDSERVER_BASE_PORT default: random high port range per run
#   MC_SIM_KEEP_SERVER_RUNNING default: 1 when easy mode is enabled
#   MC_SIM_PLAYER_NAMES optional: human player names to teleport into the meadow
#   MC_SIM_OPERATOR_NAMES optional: human player names to op for gamemode/tp
#   MC_SIM_SPECTATOR_NAMES optional: human player names to switch to spectator
MC_SIM_SMOKE_HOURS=
MC_SIM_SOAK_HOURS=
MC_SIM_LOG_DIR=
MC_SIM_DISABLE_MANAGEMENT=
MC_SIM_INCLUDE_BRIDGE_BOT=
MC_SIM_BLOCK_PRIVATE_CONVERSATIONS=
MC_SIM_ALLOW_NEW_ACTION=
MC_SIM_SUPPRESS_ACTION_CHAT=
MC_SIM_SAFE_TERRAIN_ACTIONS=
MC_SIM_EASY_MODE=
MC_SIM_MC_PORT=
MC_SIM_MINDSERVER_BASE_PORT=
MC_SIM_KEEP_SERVER_RUNNING=
MC_SIM_PLAYER_NAMES=
MC_SIM_OPERATOR_NAMES=
MC_SIM_SPECTATOR_NAMES=
MC_SIM_INIT_MESSAGE=
# Builder-plan routing for `MC_SIM_BUILD_MODE=plan`. Defaults keep plan
# generation local-only through LOCAL_LLM_MODEL_BUILDING; OpenRouter is opt-in
# and only used for purpose=plan_generation.
#   MC_SIM_BUILD_MODE default: single
#   MC_SIM_BUILDER_PROVIDER default: local
#   MC_SIM_BUILDER_FALLBACK default: fail
#   MC_SIM_BUILDER_MAX_CALLS_PER_RUN default: 12
#   MC_SIM_BUILDER_MAX_CALLS_PER_AGENT default: 3
#   MC_SIM_BUILD_MAX_PER_AGENT default: 6
#   MC_SIM_BUILD_COOLDOWN_SEC default: 300
#   MC_SIM_BUILD_ZONE_STRIDE default: 12
#   MC_SIM_BUILD_CACHE_TTL_SEC default: 3600
MC_SIM_BUILD_MODE=
MC_SIM_BUILDER_PROVIDER=
MC_SIM_BUILDER_OPENROUTER_API_KEY=
MC_SIM_BUILDER_OPENROUTER_MODEL=
MC_SIM_BUILDER_FALLBACK=
MC_SIM_BUILDER_MAX_CALLS_PER_RUN=
MC_SIM_BUILDER_MAX_CALLS_PER_AGENT=
MC_SIM_BUILDER_MAX_USD_PER_RUN=
MC_SIM_BUILDER_USD_PER_1K_INPUT=
MC_SIM_BUILDER_USD_PER_1K_OUTPUT=
MC_SIM_BUILD_MAX_PER_AGENT=
MC_SIM_BUILD_COOLDOWN_SEC=
MC_SIM_BUILD_ZONE_STRIDE=
MC_SIM_BUILD_CACHE_TTL_SEC=
# Runtime Python-memory context injection for Mindcraft decisions.
# Defaults: enabled=1, recall_limit=3, core_max=1500, recall_max=1200,
# exclude_agents=management,alpha.
MC_SIM_MEMORY_CONTEXT_ENABLED=
MC_SIM_MEMORY_RECALL_LIMIT=
MC_SIM_MEMORY_CORE_MAX_CHARS=
MC_SIM_MEMORY_RECALL_MAX_CHARS=
MC_SIM_MEMORY_CONTEXT_EXCLUDE_AGENTS=
# Optional local-LM timeout if Management review is enabled for Minecraft chat.
#   MINECRAFT_MANAGEMENT_REVIEW_DEADLINE_MS default: 10000
MINECRAFT_MANAGEMENT_REVIEW_DEADLINE_MS=
# Bridge WebSocket URL the Node client dials. Defaults to the local backend.
#   MINECRAFT_BRIDGE_URL default: ws://127.0.0.1:8010/api/minecraft/bridge/ws
MINECRAFT_BRIDGE_URL=
# Server-side escape hatch for constrained local clients that cannot set
# WebSocket Authorization headers. Default is off because bearer tokens in URLs
# can leak through logs/history. Set to 1 only for local harnesses/fallbacks.
MINECRAFT_BRIDGE_ALLOW_QUERY_TOKEN=
# E4-5 (#544) resilience tuning — all optional; sane production defaults shown.
# Max concurrent bridge round-trips; extra calls fail-closed (bridge_overloaded)
# instead of queueing unboundedly. Default: 8.
MINECRAFT_BRIDGE_MAX_INFLIGHT=
# After this many consecutive connect-class failures the circuit opens and
# calls fail-fast (bridge_unreachable → bot safe-idles). Default: 3.
MINECRAFT_BRIDGE_CIRCUIT_THRESHOLD=
# Background reconnect-probe backoff while the circuit is open: first delay
# (ms), doubled + jittered up to the cap on each failed probe. Defaults: 500.
MINECRAFT_BRIDGE_RECONNECT_BASE_MS=
# Reconnect-probe backoff ceiling (ms) — the probe never waits longer than
# this between attempts. Default: 30000.
MINECRAFT_BRIDGE_RECONNECT_MAX_MS=
# Kill-switch poll cadence for Node bots. When active, world/action verbs
# safe-idle locally within this window plus at most one in-flight bridge
# deadline. Default: 2000.
MINECRAFT_BRIDGE_KILL_POLL_MS=

# Website (used by Next.js rewrite proxy — server-side only)
BACKEND_URL=http://localhost:8010
NEXT_PUBLIC_WS_URL=ws://localhost:8010/ws
