# scripts/minecraft/world.config — world-generation inputs for the private
# Minecraft server (issue #527, epic E2-2).
#
# scripts/minecraft/start-server.sh reads this file to fill in the
# world-related lines of a freshly generated server.properties. ONLY the
# fixed set of KEY=VALUE lines below is honored — the start script reads a
# hardcoded allow-list with sed; it does NOT execute this file, so adding
# other lines (or shell code) here has no effect and is not a risk.
#
# ⚠️  WORLD GEN IS A FIRST-RUN INPUT. Minecraft bakes the seed and level
#     type into the saved world the first time it is generated. Once a world
#     folder exists, editing this file changes NOTHING for that world — you
#     must start fresh (new LEVEL_NAME, fresh SERVER_DIR, or delete the world
#     folder; see the reset path in E2-5 / issue #530). Full how-and-why
#     beginner explainer: docs/minecraft/world-config.md
#
# Format: KEY=VALUE, one per line, no spaces around '=', no quotes needed.
# Lines starting with '#' are comments and are ignored.

# LEVEL_SEED — the "seed" for the world generator.
#   A seed is just a starting value (a number or word). The SAME seed always
#   produces the SAME world: identical terrain, caves, villages, ores. Leave
#   it EMPTY for a fresh random world; set it to reproduce a known world or
#   to hand someone the exact same world.
#   Examples:  LEVEL_SEED=            (empty → new random world each fresh run)
#              LEVEL_SEED=12345
#              LEVEL_SEED=alpha-loop
LEVEL_SEED=

# LEVEL_TYPE — the overall shape of the generated world.
#   minecraft:normal        standard Minecraft terrain (the usual world)
#   minecraft:flat          a flat "superflat" world (handy for builds/tests)
#   minecraft:large_biomes  normal terrain, biomes roughly 4x larger
#   minecraft:amplified     extreme, very tall terrain (heavy on the host)
LEVEL_TYPE=minecraft:normal

# LEVEL_NAME — the folder name the world is saved under, inside SERVER_DIR.
#   On a fresh run, changing this starts a brand-new world in a new folder
#   and leaves any existing world folder untouched.
LEVEL_NAME=world

# GENERATE_STRUCTURES — true or false. Whether villages, temples, ocean
#   monuments, strongholds, etc. are generated. Almost always true.
GENERATE_STRUCTURES=true

# SPAWN_PROTECTION — radius, in blocks, around the world spawn where only
#   server operators may build. 0 = no protected zone (agents can build
#   anywhere). Precise spawn coordinates are set in-game with /setworldspawn
#   and are intentionally out of scope for this file.
SPAWN_PROTECTION=0
