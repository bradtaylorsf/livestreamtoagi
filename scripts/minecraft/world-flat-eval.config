# scripts/minecraft/world-flat-eval.config - deterministic live eval world inputs.
#
# This config is consumed by the E18 live command eval runner only. It is not
# used by Minecraft soak or local character simulation runs. Keep the world
# flat, seeded, structure-free, and unprotected so command/action failures are
# attributable to the command path rather than terrain randomness.

LEVEL_SEED=livestreamtoagi-flat-eval-v1
LEVEL_TYPE=minecraft:flat
LEVEL_NAME=flat_eval_world
GENERATE_STRUCTURES=false
SPAWN_PROTECTION=0
