# scripts/minecraft/world-easy.config - local sim starter world inputs.
#
# This is intentionally separate from world.config so normal/persistent Paper
# worlds stay untouched. run-local-sim.sh uses this file with a separate
# SERVER_DIR and port for the local "super easy" character simulation.
#
# These values only affect the first generation of a fresh SERVER_DIR. The
# resource-rich spawn itself is made deterministic by setup-easy-spawn.mjs.

LEVEL_SEED=livestreamtoagi-easy-meadow-v1
LEVEL_TYPE=minecraft:normal
LEVEL_NAME=easy_world
GENERATE_STRUCTURES=true
SPAWN_PROTECTION=0
