# Docker
docker/data/

# Minecraft server runtime (default SERVER_DIR for scripts/minecraft/start-server.sh)
# World data, the Paper jar, eula.txt and logs are local runtime artifacts.
minecraft-server/
# Easy-mode Minecraft server runtime (default SERVER_DIR when MC_SIM_EASY_MODE=1
# in scripts/minecraft/run-local-sim.sh and soak.sh). Same shape as
# minecraft-server/: world data, Paper jar, libraries — all regenerated locally.
minecraft-server-easy/
minecraft-server-easy-*/

# Mindcraft working clone (default MINDCRAFT_DIR for scripts/minecraft/setup-mindcraft.sh)
# A local pinned checkout + node_modules — NOT a vendored copy. The only
# committed artifact is scripts/minecraft/mindcraft-package-lock.json.
/mindcraft/

# Build artifacts
frontend/dist/
website/.vercel/

# Generated by website/scripts/sync-replay-assets.mjs
website/public/replay-assets/

# Logs
*.log
logs/

# Alpha-loop ephemeral data
.alpha-loop/sessions/
!.alpha-loop/learnings/proposed-updates/
.alpha-loop/traces/

# Session metadata
review-batch.json
review-session.json
review-issue-*.json
simulations-after-wait.yaml

# Assets (large binaries — track with Git LFS or download separately)
# frontend/public/assets/tilesets/*.png
# frontend/public/assets/sprites/*.png
research/**/*.pdf

# Claude Code session runtime artifacts
.claude/scheduled_tasks.lock
# Alpha-loop ephemeral data (not shared)
.alpha-loop/auth/
.alpha-loop/templates/*.bak
.worktrees/

# E22 generated artifacts — per-run sim folders, CLI build outputs, smoke
# scratch. Top-level snapshots/*.json fixtures (conflict.json, mature.json,
# day3_normal.json) stay tracked.
/snapshots/cli-builds/
/snapshots/smoke-propose-new-building/
/snapshots/headless/20*Z_*/

# Auto-generated MP4 video renders from simulations.
/videos/*.mp4

# Playwright snapshots/screenshots that occasionally land at repo root from
# ad-hoc CLI use. The standard playwright-cli artifacts under .playwright-cli/
# are already ignored above.
/after-load.yaml
/loaded.yaml
/overview.png
/proposals.png
/world-events.png
/replay-gallery.png
/evals.png
