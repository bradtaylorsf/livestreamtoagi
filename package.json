{
  "name": "livestream-agi",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n docker,backend,frontend,website -c blue,green,cyan,magenta \"pnpm dev:docker\" \"pnpm dev:backend\" \"pnpm dev:frontend\" \"pnpm dev:website\"",
    "dev:docker": "docker compose up -d --wait && bash scripts/check-services.sh && echo '✓ Services ready' && tail -f /dev/null",
    "dev:backend": "sleep 3 && .venv/bin/uvicorn core.main:app --reload --port 8010 --env-file .env",
    "dev:frontend": "sleep 5 && VITE_WS_URL=ws://localhost:8010/ws npm --prefix frontend run dev",
    "dev:website": "sleep 5 && cd website && BACKEND_URL=http://localhost:8010 npm run dev -- --webpack --port 4000",
    "pretest": "npm --prefix frontend install --silent && npm --prefix website install --silent",
    "test": "concurrently -g -n pytest,frontend,website -c yellow,cyan,magenta \".venv/bin/pytest\" \"npm --prefix frontend test\" \"npm --prefix website test\"",
    "test:python": ".venv/bin/pytest",
    "test:frontend": "npm --prefix frontend test",
    "test:website": "npm --prefix website test",
    "verify:minecraft-server": ".venv/bin/pytest tests/backend/test_minecraft_start_server.py tests/backend/test_minecraft_world_config.py tests/backend/test_minecraft_supervision.py tests/backend/test_minecraft_backup_restore.py tests/backend/test_minecraft_health.py tests/backend/test_minecraft_runbook.py -v",
    "verify:mindcraft-fork": ".venv/bin/pytest tests/backend/test_minecraft_setup_mindcraft.py -v",
    "verify:mindcraft-fork-maintenance": ".venv/bin/pytest tests/backend/test_minecraft_fork_maintenance.py -v",
    "verify:mindcraft-connect": ".venv/bin/pytest tests/backend/test_minecraft_connect_stock_bot.py -v",
    "verify:mindcraft-routing": ".venv/bin/pytest tests/backend/test_mc_model_routing.py -v",
    "verify:mindcraft-profiles": ".venv/bin/pytest tests/backend/test_mc_profile_gen.py tests/backend/test_mc_personality_mapping.py -v",
    "verify:mindcraft-stripped": ".venv/bin/pytest tests/backend/test_mc_stripped_features.py -v",
    "verify:mindcraft-routing-contract": ".venv/bin/pytest tests/backend/test_mc_routing_fork_contract.py -v",
    "verify:bridge-protocol": ".venv/bin/pytest tests/backend/test_bridge_protocol_decision.py -v",
    "verify:bridge-contract": ".venv/bin/pytest tests/backend/test_bridge_contract.py -v",
    "verify:bridge-server": ".venv/bin/pytest tests/backend/test_bridge_server.py -v",
    "verify:bridge-node-client": ".venv/bin/pytest tests/backend/test_bridge_node_client.py -v",
    "verify:bridge-observability": ".venv/bin/pytest tests/backend/test_bridge_observability.py -v",
    "verify:bridge-integration-harness": ".venv/bin/pytest tests/integration/test_bridge_harness.py -v",
    "verify:bridge-security": ".venv/bin/pytest tests/backend/test_bridge_security.py -v",
    "verify:embodiment-movement": ".venv/bin/pytest tests/backend/test_embodiment_movement.py -v",
    "verify:embodiment-building": ".venv/bin/pytest tests/backend/test_embodiment_building.py -v",
    "verify:embodiment-build-plan": ".venv/bin/pytest tests/backend/test_embodiment_build_plan.py -v",
    "verify:embodiment-code-execution": ".venv/bin/pytest tests/backend/test_embodiment_code_execution.py -v",
    "verify:embodiment-perception": ".venv/bin/pytest tests/backend/test_embodiment_perception.py -v",
    "verify:embodiment-failure": ".venv/bin/pytest tests/backend/test_embodiment_failure.py -v",
    "verify:embodiment-action-interruption": ".venv/bin/pytest tests/backend/test_embodiment_action_interruption.py -v",
    "verify:embodiment-integration": ".venv/bin/pytest tests/integration/test_embodiment_skills.py -v",
    "verify:memory-bridge-perf": ".venv/bin/pytest tests/backend/test_memory_bridge_perf.py -v -m \"not integration\"",
    "chat": ".venv/bin/python scripts/chat.py",
    "sim": ".venv/bin/python scripts/chat.py sim",
    "sim:awakening": ".venv/bin/python scripts/chat.py sim awakening",
    "sim:tools": ".venv/bin/python scripts/chat.py sim tool-coverage",
    "sim:auto": ".venv/bin/python scripts/chat.py sim autonomous",
    "eval": ".venv/bin/python scripts/chat.py eval",
    "coverage": ".venv/bin/python scripts/chat.py coverage",
    "llm:local": ".venv/bin/python scripts/check_local_llm.py",
    "mc:eval:commands": ".venv/bin/python scripts/minecraft/eval_commands.py",
    "mc:eval:commands:smoke": "pnpm mc:eval:commands --dry-run --list-only",
    "mc:eval:commands:dry-run": "pnpm mc:eval:commands --dry-run",
    "mc:eval:live": ".venv/bin/python scripts/minecraft/eval_live.py",
    "mc:eval:live:smoke": "pnpm mc:eval:live --command move --cases 3 --dry-run",
    "mc:eval:replay": ".venv/bin/python scripts/minecraft/eval_replay.py",
    "mc:eval:replay:smoke": "pnpm mc:eval:replay --dataset tests/backend/fixtures/mc_eval/sample-passing-prompts.ndjson --limit 2 --dry-run",
    "verify:mc-eval-live-profile": ".venv/bin/pytest tests/backend/test_mc_eval_live_profile.py -v",
    "verify:mc-eval-live": ".venv/bin/pytest tests/backend/test_mc_eval_live_cli.py tests/backend/test_mc_eval_live_runner.py tests/backend/test_mc_eval_live_telemetry.py -v",
    "verify:mc-eval-replay": ".venv/bin/pytest tests/backend/test_mc_eval_dataset_replay.py tests/backend/test_mc_eval_replay_cli.py -v",
    "verify:mc-eval-commands": ".venv/bin/pytest tests/backend/test_mc_eval_live_profile.py tests/backend/test_mc_eval_live_cli.py tests/backend/test_mc_eval_live_runner.py tests/backend/test_mc_eval_live_telemetry.py tests/backend/test_mc_eval_cli.py tests/backend/test_mc_eval_evaluator.py tests/backend/test_mc_eval_parser.py tests/backend/test_mc_eval_provider.py tests/backend/test_mc_eval_report.py tests/backend/test_mc_eval_runner.py -v",
    "mc:verify-routing": "scripts/minecraft/verify-model-routing.sh --verify",
    "mc:gen-profiles": ".venv/bin/python scripts/minecraft/gen_profiles.py",
    "mc:connect-bridge": "scripts/minecraft/connect-bridge-bot.sh",
    "mc:connect-alpha": "scripts/minecraft/connect-alpha-bot.sh",
    "mc:soak": "scripts/minecraft/soak.sh",
    "mc:sim": "scripts/minecraft/run-local-sim.sh",
    "mc:sim:smoke": "scripts/minecraft/run-local-sim.sh smoke",
    "mc:sim:soak": "scripts/minecraft/run-local-sim.sh soak",
    "mc:sim:smoke:director": "scripts/minecraft/run-local-sim.sh smoke-director",
    "mc:sim:soak:director": "scripts/minecraft/run-local-sim.sh soak-director",
    "mc:run-errand-smoke": ".venv/bin/pytest tests/backend/test_minecraft_alpha_errand_execution.py -v",
    "verify:mindcraft-alpha": ".venv/bin/pytest tests/backend/test_minecraft_alpha_profile.py -v",
    "verify:alpha-errand": ".venv/bin/pytest tests/backend/test_minecraft_alpha_errand_execution.py tests/backend/test_bridge_errand.py -v",
    "verify:minecraft-soak": ".venv/bin/pytest tests/backend/test_minecraft_multi_agent_soak.py -v",
    "verify:director-acceptance-soak": ".venv/bin/pytest tests/backend/test_minecraft_director_acceptance_soak.py -v",
    "reflect": ".venv/bin/python scripts/test_agent.py --reflect --all",
    "reflect:agent": ".venv/bin/python scripts/test_agent.py --reflect --agent",
    "report": ".venv/bin/python scripts/report_simulation.py",
    "snapshot": ".venv/bin/python scripts/snapshot_memory.py",
    "restore": ".venv/bin/python scripts/restore_memory.py",
    "db:migrate": ".venv/bin/python -m db up",
    "db:status": ".venv/bin/python -m db status",
    "db:rollback": ".venv/bin/python -m db down",
    "stop": "docker compose down && echo '✓ Services stopped'"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
